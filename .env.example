# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL (wird in docker-compose gesetzt, hier für lokale Entwicklung)
DATABASE_URL=postgresql://sim_user:sim_pass@localhost:5432/simulation

# Simulation Defaults
DEFAULT_TICK_DURATION_DAYS=15        # Ingame-Tage pro Stunde Realzeit
DEFAULT_AGENT_CONCURRENT_CALLS=10   # Parallele API-Calls im Tick-Loop
MAX_CONCURRENT_CALLS=20
MAX_CONCURRENT_SIMULATIONS=3

# Admin Master Key (für /admin/* Endpoints)
ADMIN_MASTER_KEY=change-me-in-production

# CORS (in Produktion auf eigene Domain einschränken)
# CORS_ORIGINS=["https://app.meinedomain.de"]

# Debug-Modus (zeigt Exception-Details in API-Responses)
DEBUG=false
